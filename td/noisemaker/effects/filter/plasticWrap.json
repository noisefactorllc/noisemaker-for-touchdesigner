{
  "name": "Plastic Wrap",
  "namespace": "filter",
  "func": "plasticWrap",
  "starter": false,
  "tags": [
    "blur",
    "edges"
  ],
  "description": "Glossy specular plastic film hugging image contours",
  "paramAliases": {},
  "globals": {
    "highlight": {
      "type": "float",
      "default": 60,
      "uniform": "highlight",
      "min": 0,
      "max": 100,
      "zero": 0
    },
    "detail": {
      "type": "float",
      "default": 40,
      "uniform": "detail",
      "min": 0,
      "max": 100
    },
    "smoothness": {
      "type": "float",
      "default": 30,
      "uniform": "smoothness",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "blurH",
      "program": "pwBlurH",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "_pwBlurH"
      }
    },
    {
      "name": "blurV",
      "program": "pwBlurV",
      "inputs": {
        "inputTex": "_pwBlurH"
      },
      "outputs": {
        "fragColor": "_pwBlur"
      }
    },
    {
      "name": "spec",
      "program": "pwSpec",
      "inputs": {
        "inputTex": "inputTex",
        "blurTex": "_pwBlur"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "_pwBlurH": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    },
    "_pwBlur": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    }
  }
}
