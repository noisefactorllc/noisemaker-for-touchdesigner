{
  "name": "Photocopy",
  "namespace": "filter",
  "func": "photocopy",
  "starter": false,
  "tags": [
    "blur",
    "edges"
  ],
  "description": "Edge-band ink on paper via difference-of-Gaussians, like a bad photocopy",
  "paramAliases": {},
  "globals": {
    "detail": {
      "type": "float",
      "default": 30,
      "uniform": "detail",
      "min": 1,
      "max": 100
    },
    "darkness": {
      "type": "float",
      "default": 50,
      "uniform": "darkness",
      "min": 0,
      "max": 100
    },
    "inkColor": {
      "type": "color",
      "default": [
        0.1,
        0.1,
        0.1
      ],
      "uniform": "inkColor"
    },
    "paperColor": {
      "type": "color",
      "default": [
        0.96,
        0.94,
        0.88
      ],
      "uniform": "paperColor"
    }
  },
  "passes": [
    {
      "name": "blurH",
      "program": "pcBlurH",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "_pcBlurH"
      }
    },
    {
      "name": "blurV",
      "program": "pcBlurV",
      "inputs": {
        "inputTex": "_pcBlurH"
      },
      "outputs": {
        "fragColor": "_pcBlur"
      }
    },
    {
      "name": "combine",
      "program": "pcCombine",
      "inputs": {
        "inputTex": "inputTex",
        "blurTex": "_pcBlur"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "_pcBlurH": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    },
    "_pcBlur": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    }
  }
}
