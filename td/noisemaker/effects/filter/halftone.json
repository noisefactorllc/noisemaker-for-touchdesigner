{
  "name": "Halftone",
  "namespace": "filter",
  "func": "halftone",
  "starter": false,
  "tags": [
    "color",
    "pixel",
    "artist"
  ],
  "description": "Rotated-screen halftone reproduction with subtractive color rosettes or monochrome dot, line, and circle screens",
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 0,
      "define": "MODE",
      "choices": {
        "color": 0,
        "mono": 1
      }
    },
    "pattern": {
      "type": "int",
      "default": 0,
      "define": "PATTERN",
      "choices": {
        "dot": 0,
        "line": 1,
        "circle": 2
      }
    },
    "frequency": {
      "type": "float",
      "default": 24,
      "uniform": "frequency",
      "min": 4,
      "max": 128
    },
    "cyanAngle": {
      "type": "float",
      "default": 108,
      "uniform": "cyanAngle",
      "min": -180,
      "max": 180
    },
    "magentaAngle": {
      "type": "float",
      "default": 162,
      "uniform": "magentaAngle",
      "min": -180,
      "max": 180
    },
    "yellowAngle": {
      "type": "float",
      "default": 90,
      "uniform": "yellowAngle",
      "min": -180,
      "max": 180
    },
    "blackAngle": {
      "type": "float",
      "default": 45,
      "uniform": "blackAngle",
      "min": -180,
      "max": 180
    },
    "monoAngle": {
      "type": "float",
      "default": 45,
      "uniform": "monoAngle",
      "min": -180,
      "max": 180
    },
    "sharpness": {
      "type": "float",
      "default": 80,
      "uniform": "sharpness",
      "min": 0,
      "max": 100
    },
    "inkColor": {
      "type": "color",
      "default": [
        0.05,
        0.05,
        0.05
      ],
      "uniform": "inkColor"
    },
    "paperColor": {
      "type": "color",
      "default": [
        0.98,
        0.96,
        0.9
      ],
      "uniform": "paperColor"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "halftone",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {}
}
