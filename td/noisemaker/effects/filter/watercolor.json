{
  "name": "Watercolor",
  "namespace": "filter",
  "func": "watercolor",
  "starter": false,
  "tags": [
    "blur",
    "edges",
    "artist"
  ],
  "description": "Simplified color washes with pigment pooling at edges and paper granulation",
  "paramAliases": {},
  "globals": {
    "detail": {
      "type": "float",
      "default": 50,
      "uniform": "detail",
      "min": 0,
      "max": 100
    },
    "shadowIntensity": {
      "type": "float",
      "default": 40,
      "uniform": "shadowIntensity",
      "min": 0,
      "max": 100
    },
    "paperTexture": {
      "type": "float",
      "default": 30,
      "uniform": "paperTexture",
      "min": 0,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "seed",
      "program": "wcSeed",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "global_wc_state"
      }
    },
    {
      "name": "wcSimplify",
      "program": "wcSimplify",
      "inputs": {
        "inputTex": "global_wc_state"
      },
      "outputs": {
        "fragColor": "global_wc_state"
      },
      "repeat": 2
    },
    {
      "name": "wcComposite",
      "program": "wcComposite",
      "inputs": {
        "inputTex": "inputTex",
        "simplifiedTex": "global_wc_state"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "global_wc_state": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}
